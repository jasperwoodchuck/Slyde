{
	"compilerOptions": {
		"baseUrl": "src",
		"target": "ES2018",
		"module": "ESNext",
		"moduleResolution": "node10",
		"strict": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"importHelpers": true,
		"types": [
			"obsidian"
		],
		"lib": [
			"DOM",
			"ES2018"
		],
		"isolatedModules": true,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts"
	]
}